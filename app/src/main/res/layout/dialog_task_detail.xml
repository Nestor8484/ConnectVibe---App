<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvDialogTaskName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            tools:text="Preparar música"
            android:textColor="#1565C0"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvDialogTaskRole"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_dot_outline"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            tools:text="Logística"
            android:textColor="#1565C0"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Descripción"
            android:textColor="#1565C0"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvDialogTaskDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="@color/md_theme_onSurface"
            android:layout_marginBottom="24dp"
            tools:text="Debes traer los altavoces y la lista de reproducción preparada." />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNotifyTask"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NOTIFICAR A LOS RESPONSABLES"
            android:textColor="@android:color/white"
            android:backgroundTint="#1565C0"
            app:icon="@android:drawable/ic_lock_idle_alarm"
            app:cornerRadius="12dp"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteTask"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Eliminar"
                android:textColor="@color/md_theme_error" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCloseTask"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cerrar" />

        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
