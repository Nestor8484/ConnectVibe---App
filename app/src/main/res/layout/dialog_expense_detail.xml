<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvDialogExpenseName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            android:textColor="#0D47A1"
            android:textSize="24sp"
            android:textStyle="bold"
            tools:text="Nombre del Gasto" />

        <TextView
            android:id="@+id/tvDialogExpenseAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textAlignment="center"
            android:textColor="#1565C0"
            android:textSize="20sp"
            android:textStyle="bold"
            tools:text="0.00€" />

        <TextView
            android:id="@+id/tvDialogExpenseType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_title_container"
            android:paddingHorizontal="16dp"
            android:paddingVertical="6dp"
            android:textColor="#1565C0"
            android:textSize="14sp"
            tools:text="Tipo: Comida" />

        <TextView
            android:id="@+id/tvDialogExpenseDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textAlignment="center"
            android:textColor="@color/md_theme_onSurfaceVariant"
            android:textSize="14sp"
            tools:text="Esta es la descripción del gasto" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Detalles del pago:"
            android:textColor="@color/md_theme_onSurface"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDialogExpenseDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/md_theme_onSurfaceVariant"
            tools:text="• Pagado por: Usuario\n• Fecha: 12/03/2024" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEditExpense"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:paddingVertical="12dp"
            android:text="Editar Gasto"
            android:visibility="gone"
            app:cornerRadius="12dp"
            app:icon="@android:drawable/ic_menu_edit"
            tools:visibility="visible" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDeleteExpense"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Eliminar Gasto"
            android:textColor="@color/design_default_color_error"
            android:visibility="gone"
            app:icon="@android:drawable/ic_menu_delete"
            app:iconTint="@color/design_default_color_error"
            tools:visibility="visible" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCloseExpense"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cerrar" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>