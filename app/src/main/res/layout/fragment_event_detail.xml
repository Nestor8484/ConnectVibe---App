<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurface"
        app:elevation="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="20dp"
            android:paddingTop="32dp"
            android:paddingBottom="16dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_back"
                app:layout_constraintBottom_toBottomOf="@id/tvEventTitleContainer"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/tvEventTitleContainer"
                app:tint="@color/md_theme_onSurface" />

            <TextView
                android:id="@+id/tvEventTitleContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:background="@drawable/bg_title_container"
                android:paddingHorizontal="24dp"
                android:paddingVertical="16dp"
                android:textAlignment="center"
                android:textColor="@color/md_theme_onPrimaryContainer"
                android:textSize="24sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/ivUserProfile"
                app:layout_constraintStart_toEndOf="@id/btnBack"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="Evento" />

            <ImageView
                android:id="@+id/ivUserProfile"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:padding="6dp"
                android:src="@drawable/ic_profile"
                app:layout_constraintBottom_toBottomOf="@id/tvEventTitleContainer"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tvEventTitleContainer"
                app:tint="@color/md_theme_onSurface" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="2dp"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Info de Participación -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp"
            android:paddingHorizontal="8dp">

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/cbParticipateDetail"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Participar en este evento"
                android:textColor="?attr/colorPrimary"
                android:buttonTint="?attr/colorPrimary"
                android:textStyle="bold"
                android:textSize="11sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_dot_outline"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:layout_marginStart="8dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_groups"
                    app:tint="?attr/colorPrimary"/>

                <TextView
                    android:id="@+id/tvParticipantCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12 participantes"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorPrimary"
                    android:layout_marginStart="6dp"/>
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/bg_content_box"
            android:orientation="vertical"
            android:padding="4dp">

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                app:tabIndicatorColor="?attr/colorPrimary"
                app:tabSelectedTextColor="?attr/colorPrimary"
                app:tabTextColor="@color/md_theme_onSurfaceVariant"
                app:tabTextAppearance="@style/TextAppearance.Material3.TitleSmall" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ScrollView
                    android:id="@+id/layoutInfo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="visible"
                    android:fillViewport="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:paddingBottom="150dp"
                        android:clipToPadding="false">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp">

                            <TextView
                                android:id="@+id/tvGeneralInfoTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentStart="true"
                                android:layout_centerVertical="true"
                                android:layout_toStartOf="@id/llActionButtons"
                                android:text="Información General"
                                android:textColor="?attr/colorPrimary"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:id="@+id/llActionButtons"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnStatusAction"
                                    style="@style/Widget.Material3.Button.TonalButton"
                                    android:layout_width="wrap_content"
                                    android:layout_height="36dp"
                                    android:paddingHorizontal="16dp"
                                    android:insetTop="0dp"
                                    android:insetBottom="0dp"
                                    android:text="Iniciar"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:visibility="gone"
                                    app:cornerRadius="18dp"
                                    tools:visibility="visible" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnEditEvent"
                                    style="@style/Widget.Material3.Button.IconButton"
                                    android:layout_width="44dp"
                                    android:layout_height="44dp"
                                    android:layout_marginStart="8dp"
                                    android:visibility="gone"
                                    app:icon="@android:drawable/ic_menu_edit"
                                    app:iconSize="24dp"
                                    app:iconTint="?attr/colorPrimary"
                                    tools:visibility="visible" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnDeleteEvent"
                                    style="@style/Widget.Material3.Button.IconButton"
                                    android:layout_width="44dp"
                                    android:layout_height="44dp"
                                    android:layout_marginStart="4dp"
                                    android:visibility="gone"
                                    app:icon="@android:drawable/ic_menu_delete"
                                    app:iconSize="24dp"
                                    app:iconTint="#D32F2F"
                                    tools:visibility="visible" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnLeaveEvent"
                                    style="@style/Widget.Material3.Button.IconButton"
                                    android:layout_width="44dp"
                                    android:layout_height="44dp"
                                    android:layout_marginStart="4dp"
                                    android:visibility="gone"
                                    app:icon="@android:drawable/ic_menu_close_clear_cancel"
                                    app:iconSize="24dp"
                                    app:iconTint="#D32F2F"
                                    tools:visibility="visible" />
                            </LinearLayout>
                        </RelativeLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Descripción"
                            android:textColor="?attr/colorPrimary"
                            android:textStyle="bold"
                            android:textSize="13sp"/>

                        <TextView
                            android:id="@+id/tvInfoDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textColor="@color/md_theme_onSurfaceVariant"
                            android:textSize="13sp"
                            tools:text="Esta es la descripción detallada del evento." />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="24dp"
                            android:text="@string/label_date"
                            android:textColor="?attr/colorPrimary"
                            android:textStyle="bold"
                            android:textSize="14sp"/>

                        <TextView
                            android:id="@+id/tvInfoDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textColor="@color/md_theme_onSurfaceVariant"
                            android:textSize="13sp"
                            tools:text="15 de Octubre, 2024" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="24dp"
                            android:text="Ubicación"
                            android:textColor="?attr/colorPrimary"
                            android:textStyle="bold"
                            android:textSize="14sp"/>

                        <TextView
                            android:id="@+id/tvInfoLocation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textColor="@color/md_theme_onSurfaceVariant"
                            android:textSize="13sp"
                            android:text="Ubicación no especificada" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="24dp"
                            android:text="Participantes"
                            android:textColor="?attr/colorPrimary"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:layout_marginBottom="8dp"/>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvParticipantsDetail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:nestedScrollingEnabled="false"
                            tools:listitem="@layout/item_participant" />
                    </LinearLayout>
                </ScrollView>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvRoles"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:padding="8dp"
                    android:paddingBottom="120dp"
                    tools:listitem="@layout/item_role" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvExpenses"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:padding="8dp"
                    android:paddingBottom="120dp"
                    android:visibility="gone"
                    tools:listitem="@layout/item_expense" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvTasks"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:padding="8dp"
                    android:paddingBottom="120dp"
                    android:visibility="gone"
                    tools:listitem="@layout/item_task" />

                <ScrollView
                    android:id="@+id/layoutDashboard"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone"
                    android:clipToPadding="false"
                    android:paddingBottom="120dp"
                    android:fillViewport="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Tarjeta de Resumen Rápido -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:cardBackgroundColor="?attr/colorSecondaryContainer"
                            app:cardCornerRadius="16dp"
                            app:strokeWidth="0dp">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:padding="16dp"
                                android:weightSum="2">
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Gasto Total"
                                        android:textSize="12sp"
                                        android:textColor="?attr/colorOnSecondaryContainer"/>
                                    <TextView
                                        android:id="@+id/tvTotalExpense"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0.00€"
                                        android:textSize="20sp"
                                        android:textStyle="bold"
                                        android:textColor="?attr/colorOnSecondaryContainer"/>
                                </LinearLayout>
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Roles Cubiertos"
                                        android:textSize="12sp"
                                        android:textColor="?attr/colorOnSecondaryContainer"/>
                                    <TextView
                                        android:id="@+id/tvRolesCovered"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0 de 0"
                                        android:textSize="20sp"
                                        android:textStyle="bold"
                                        android:textColor="?attr/colorOnSecondaryContainer"/>
                                </LinearLayout>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Gastos por Categoría"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnToggleChartType"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ver en Barras"
                            app:icon="@android:drawable/ic_menu_sort_by_size"
                            android:layout_gravity="end"/>

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="240dp"
                            android:layout_marginBottom="16dp">

                            <com.tuapp.eventos.ui.views.SimplePieChartView
                                android:id="@+id/viewPieChart"
                                android:layout_width="200dp"
                                android:layout_height="200dp"
                                android:layout_gravity="center" />

                            <LinearLayout
                                android:id="@+id/viewBarChart"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="horizontal"
                                android:gravity="bottom"
                                android:visibility="gone"
                                android:paddingHorizontal="24dp">

                                <View android:layout_width="0dp" android:layout_height="180dp" android:layout_weight="1" android:background="#1565C0" android:layout_marginHorizontal="8dp"/>
                                <View android:layout_width="0dp" android:layout_height="120dp" android:layout_weight="1" android:background="#1E88E5" android:layout_marginHorizontal="8dp"/>
                                <View android:layout_width="0dp" android:layout_height="60dp" android:layout_weight="1" android:background="#64B5F6" android:layout_marginHorizontal="8dp"/>
                                <View android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:background="#BBDEFB" android:layout_marginHorizontal="8dp"/>
                            </LinearLayout>
                        </FrameLayout>

                        <!-- Leyenda detallada -->
                        <GridLayout
                            android:id="@+id/layoutExpenseLegend"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:columnCount="2"
                            android:layout_marginBottom="24dp">

                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center_vertical" android:padding="4dp" android:layout_columnWeight="1">
                                <View android:layout_width="12dp" android:layout_height="12dp" android:background="#1565C0"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" Comida (125€)" android:textSize="12sp" android:layout_marginStart="8dp"/>
                            </LinearLayout>
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center_vertical" android:padding="4dp" android:layout_columnWeight="1">
                                <View android:layout_width="12dp" android:layout_height="12dp" android:background="#1E88E5"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" Bebida (80€)" android:textSize="12sp" android:layout_marginStart="8dp"/>
                            </LinearLayout>
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center_vertical" android:padding="4dp" android:layout_columnWeight="1">
                                <View android:layout_width="12dp" android:layout_height="12dp" android:background="#64B5F6"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" Logística (45€)" android:textSize="12sp" android:layout_marginStart="8dp"/>
                            </LinearLayout>
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center_vertical" android:padding="4dp" android:layout_columnWeight="1">
                                <View android:layout_width="12dp" android:layout_height="12dp" android:background="#BBDEFB"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" Otros (25€)" android:textSize="12sp" android:layout_marginStart="8dp"/>
                            </LinearLayout>
                        </GridLayout>

                    </LinearLayout>
                </ScrollView>

            </FrameLayout>

        </LinearLayout>

    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddRole"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="12dp"
        android:contentDescription="@string/add_role"
        app:srcCompat="@android:drawable/ic_input_add"
        android:visibility="gone"
        app:backgroundTint="?attr/colorPrimary"
        app:tint="?attr/colorOnPrimary" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddExpense"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="12dp"
        android:contentDescription="@string/add_expense"
        app:srcCompat="@android:drawable/ic_input_add"
        android:visibility="gone"
        app:backgroundTint="?attr/colorPrimary"
        app:tint="?attr/colorOnPrimary" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>